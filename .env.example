# Server
PORT=8080
NODE_ENV=development

# CORS: comma-separated origins (empty = reflect request origin in dev)
CORS_ORIGINS=http://localhost:5173

# Redis (optional — server uses in-memory LRU cache if unset or unreachable)
REDIS_URL=redis://127.0.0.1:6379

# Max inclusive count (max − min + 1) for range queries; capped at 50000
ROMAN_MAX_RANGE_SIZE=10000

# Cache TTL for Roman results (seconds)
CACHE_TTL_SECONDS=3600

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
